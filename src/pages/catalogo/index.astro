---
import BaseLayout from '../../layouts/BaseLayout.astro';
const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
---

<BaseLayout title="Maquinas Virtuales | DTP Automation" description="Redireccionando a Maquinas Virtuales." bodyClass="site-catalog">
  <main>
    <meta http-equiv="refresh" content="0;url=/categorias/vm/" />
    <section class="page-hero">
      <div class="container page-hero-grid">
        <div>
          <span class="eyebrow">Maquinas Virtuales</span>
          <h1>Este apartado ahora forma parte de Maquinas Virtuales</h1>
          <p class="section-copy">
            Si no eres redirigido automaticamente, puedes continuar desde la seccion principal de maquinas virtuales.
          </p>
          <a class="btn" href={`${baseUrl}categorias/vm/`}>Ir a Maquinas Virtuales</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
