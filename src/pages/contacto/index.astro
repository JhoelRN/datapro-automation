---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto | DTP Automation" description="Redireccionando a Nosotros." bodyClass="site-contact">
  <main>
    <meta http-equiv="refresh" content="0;url=/nosotros/#contacto" />
    <section class="page-hero">
      <div class="container page-hero-grid">
        <div>
          <span class="eyebrow">Contacto</span>
          <h1>Esta informacion ahora forma parte de Nosotros</h1>
          <p class="section-copy">
            Si no eres redirigido automaticamente, puedes ir directamente a la seccion de contacto dentro de Nosotros.
          </p>
          <a class="btn" href="/nosotros/#contacto">Ir a Nosotros</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
