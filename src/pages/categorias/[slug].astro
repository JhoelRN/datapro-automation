---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
import { categories, getProductsByCategory, type ProductCategory } from '../../data/catalog';

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
const items = getProductsByCategory(category.slug as ProductCategory);
const whatsappMessage = encodeURIComponent(`Hola Jhoel, tengo mi siguiente consulta: ${category.label}.`);
---

<BaseLayout title={`${category.label} | DTP Automation`} description={category.description} bodyClass="site-category">
  <Header currentPath={`/categorias/${category.slug}/`} />

  <main>
    <section class="page-hero">
      <div class="container page-hero-grid">
        <div>
          <span class="eyebrow">Categoria</span>
          <h1>{category.label}</h1>
          <p class="section-copy">{category.description}</p>
        </div>

        <div class="callout-card">
          <p><strong>{category.count}</strong> recursos en esta categoria</p>
          <p class="category-callout-copy">
            Para una consulta especifica sobre MVs o softwares, puedes escribirnos directamente y te ayudamos.
          </p>
          <a
            class="btn btn-whatsapp"
            href={`https://wa.me/51969310501?text=${whatsappMessage}`}
            target="_blank"
            rel="noopener"
          >
            <span class="social-link-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 3.2a8.8 8.8 0 0 0-7.5 13.4L3.3 21l4.6-1.2A8.8 8.8 0 1 0 12 3.2Zm0 15.9a7 7 0 0 1-3.6-1l-.3-.2-2.7.7.7-2.6-.2-.3A7 7 0 1 1 12 19.1Zm3.8-5.3c-.2-.1-1.3-.6-1.5-.7-.2-.1-.4-.1-.6.1l-.4.5c-.1.2-.3.2-.5.1a5.7 5.7 0 0 1-2.8-2.4c-.1-.2 0-.4.1-.5l.3-.4a.6.6 0 0 0 .1-.6l-.7-1.6c-.1-.2-.3-.3-.5-.3h-.4a.9.9 0 0 0-.6.3 2.6 2.6 0 0 0-.8 1.9c0 1.1.8 2.2 1 2.5a7.7 7.7 0 0 0 3 2.7c1.8.8 1.8.5 2.2.5a1.9 1.9 0 0 0 1.3-.9 1.6 1.6 0 0 0 .1-.9c-.1 0-.3-.1-.5-.2Z"/></svg>
            </span>
            <span>WhatsApp</span>
          </a>
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="container">
        <div class="category-search-feedback" data-category-search-feedback hidden>
          <p>
            Resultados para <strong data-category-search-term></strong> en <strong>{category.label}</strong>.
          </p>
        </div>

        <div class="product-grid">
          {items.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>

        <div class="category-search-empty" data-category-search-empty hidden>
          <p>No encontramos resultados con ese termino en esta categoria.</p>
        </div>
      </div>
    </section>

    <section class="section-block section-alt">
      <div class="container split-showcase">
        <div class="callout-card">
          <span class="eyebrow">Enfoque</span>
          <h2>Maquinas virtuales listas para practicar y trabajar</h2>
          <p>
            Reunimos entornos virtuales con software industrial, licencias activas y configuraciones pensadas para
            formacion, pruebas tecnicas y proyectos reales en PLC, HMI, SCADA y automatizacion.
          </p>
        </div>

        <div class="callout-card">
          <span class="eyebrow">Escalado</span>
          <h2>Catalogo preparado para crecer por marca y tecnologia</h2>
          <p>
            Cada categoria puede ampliarse con soluciones Siemens, Allen Bradley, Schneider, Omron, Fanuc y mas,
            incorporando fichas tecnicas, versiones, compatibilidades, soporte y nuevos recursos especializados.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const query = (params.get('q') || '').trim().toLowerCase();
  const cards = Array.from(document.querySelectorAll('[data-product-card]'));
  const feedback = document.querySelector('[data-category-search-feedback]');
  const feedbackTerm = document.querySelector('[data-category-search-term]');
  const emptyState = document.querySelector('[data-category-search-empty]');

  if (query && cards.length) {
    let visibleCount = 0;

    cards.forEach((card) => {
      if (!(card instanceof HTMLElement)) return;
      const filterText = (card.dataset.filterText || '').toLowerCase();
      const matches = filterText.includes(query);
      card.style.display = matches ? '' : 'none';
      if (matches) visibleCount += 1;
    });

    if (feedback instanceof HTMLElement) feedback.hidden = false;
    if (feedbackTerm instanceof HTMLElement) feedbackTerm.textContent = params.get('q') || '';
    if (emptyState instanceof HTMLElement) emptyState.hidden = visibleCount !== 0;
  }
</script>
