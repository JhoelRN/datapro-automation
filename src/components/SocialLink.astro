---
interface Props {
  href: string;
  label: string;
  tone: 'facebook' | 'instagram' | 'youtube' | 'whatsapp' | 'tiktok';
  variant?: 'pill' | 'button';
  ghost?: boolean;
  className?: string;
}

const {
  href,
  label,
  tone,
  variant = 'pill',
  ghost = false,
  className = ''
} = Astro.props;

const icons = {
  facebook: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 21v-7h2.4l.4-3h-2.8V9.2c0-.9.3-1.5 1.6-1.5H16V5.1c-.5-.1-1.3-.1-2.2-.1-2.2 0-3.8 1.3-3.8 3.9V11H7.5v3H10v7h3.5Z"/></svg>`,
  instagram: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.5 3h9A4.5 4.5 0 0 1 21 7.5v9a4.5 4.5 0 0 1-4.5 4.5h-9A4.5 4.5 0 0 1 3 16.5v-9A4.5 4.5 0 0 1 7.5 3Zm0 1.8A2.7 2.7 0 0 0 4.8 7.5v9a2.7 2.7 0 0 0 2.7 2.7h9a2.7 2.7 0 0 0 2.7-2.7v-9a2.7 2.7 0 0 0-2.7-2.7h-9Zm9.45 1.35a1.05 1.05 0 1 1 0 2.1 1.05 1.05 0 0 1 0-2.1ZM12 7.4A4.6 4.6 0 1 1 7.4 12 4.6 4.6 0 0 1 12 7.4Zm0 1.8A2.8 2.8 0 1 0 14.8 12 2.8 2.8 0 0 0 12 9.2Z"/></svg>`,
  youtube: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21.2 7.2a2.8 2.8 0 0 0-2-2C17.4 4.7 12 4.7 12 4.7s-5.4 0-7.2.5a2.8 2.8 0 0 0-2 2A29.3 29.3 0 0 0 2.3 12a29.3 29.3 0 0 0 .5 4.8 2.8 2.8 0 0 0 2 2c1.8.5 7.2.5 7.2.5s5.4 0 7.2-.5a2.8 2.8 0 0 0 2-2 29.3 29.3 0 0 0 .5-4.8 29.3 29.3 0 0 0-.5-4.8ZM10.2 15.5v-7L16 12l-5.8 3.5Z"/></svg>`,
  whatsapp: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.2a8.8 8.8 0 0 0-7.5 13.4L3.3 21l4.6-1.2A8.8 8.8 0 1 0 12 3.2Zm0 15.9a7 7 0 0 1-3.6-1l-.3-.2-2.7.7.7-2.6-.2-.3A7 7 0 1 1 12 19.1Zm3.8-5.3c-.2-.1-1.3-.6-1.5-.7-.2-.1-.4-.1-.6.1l-.4.5c-.1.2-.3.2-.5.1a5.7 5.7 0 0 1-2.8-2.4c-.1-.2 0-.4.1-.5l.3-.4a.6.6 0 0 0 .1-.6l-.7-1.6c-.1-.2-.3-.3-.5-.3h-.4a.9.9 0 0 0-.6.3 2.6 2.6 0 0 0-.8 1.9c0 1.1.8 2.2 1 2.5a7.7 7.7 0 0 0 3 2.7c1.8.8 1.8.5 2.2.5a1.9 1.9 0 0 0 1.3-.9 1.6 1.6 0 0 0 .1-.9c-.1 0-.3-.1-.5-.2Z"/></svg>`,
  tiktok: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.6 3c.4 1.7 1.4 3 3.1 3.9.8.4 1.7.6 2.6.6v2.8a8.5 8.5 0 0 1-3.1-.6v5.3a5.9 5.9 0 1 1-5.9-5.9c.3 0 .5 0 .8.1V12a3.2 3.2 0 1 0 2.5 3.1V3h2Z"/></svg>`
} as const;

const classes = [
  variant === 'button' ? 'btn btn-social-brand' : 'social-link-pill social-link-brand',
  ghost ? 'btn-ghost' : '',
  `social-link-brand-${tone}`,
  className
].filter(Boolean).join(' ');
---

<a class={classes} href={href} target="_blank" rel="noopener">
  <span class="social-link-icon" set:html={icons[tone]} />
  <span>{label}</span>
</a>
